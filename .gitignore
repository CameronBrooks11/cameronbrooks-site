# Build output — never commit compiled binaries
bin/

# Go binaries and plugins
*.exe
*.exe~
*.dll
*.so
*.dylib

# Test binary, built with `go test -c`
*.test

# Code coverage profiles and other test artifacts
*.out
coverage.*
*.coverprofile
profile.cov

# Go workspace file (local multi-module; not needed for this single-module repo)
go.work
go.work.sum

# Environment / secrets — never commit
.env
*.env

# Editor / IDE
.idea/
.vscode/

# Vim swap files
*.swp
*.swo
*~

# Logs
*.log
logs/

# OS artifacts
.DS_Store
Thumbs.db


# Generated Static Assets (optional future)
_site/
public/build/


# Misc
*.bak
*.tmp
*.old