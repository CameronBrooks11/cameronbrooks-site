{{define "content"}}
<div class="container">
  <h1>Writing</h1>
  <p class="text-muted">Notes and longer pieces.</p>

  <ul class="post-list">
    {{range .Data}}
    <li>
      <a href="/writing/{{.Slug}}">{{.Title}}</a>
      <span class="text-muted"> &mdash; {{.Date}}</span>
      <p>{{.Summary}}</p>
    </li>
    {{else}}
    <li><p class="text-muted">Nothing published yet.</p></li>
    {{end}}
  </ul>
</div>
{{end}}
